---
import Base from '../layouts/Base.astro';
---

<Base title="Music">
  <section>
    <h1>Music</h1>
    <p>
      I've been playing guitar since 2004, exploring everything from classic rock to blues and jazz. Here are a few videos from my YouTube channel.
    </p>

    <div class="videos">
      <iframe
        width="100%"
        height="315"
        src="https://www.youtube.com/embed/TmRuph7p7VE?si=KLeRsSUd4yyt6ydp"
        title="YouTube video player"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen></iframe>

      <iframe
        width="100%"
        height="315"
        src="https://www.youtube.com/embed/XC-UVj6J8-I?si=yHLvRIVF59nGimvp"
        title="YouTube video player"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen></iframe>

      <iframe
        width="100%"
        height="315"
        src="https://www.youtube.com/embed/9-BEO3__U_c?si=2pO3tSKx7EW1Lgs8"
        title="YouTube video player"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen></iframe>

      <iframe
        width="100%"
        height="315"
        src="https://www.youtube.com/embed/LIKy_qWDG3s?si=DMR83mnowvg7cV4U"
        title="YouTube video player"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen></iframe>
    </div>
  </section>
</Base>

<style>
  h1 {
    font-size: 2rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  p {
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .videos {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 2rem;
  }

  iframe {
    border: none;
    border-radius: 4px;
  }
</style>
