---
interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Eric Daoud Attoyan</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  </head>
  <body>
    <div class="container">
      <header>
        <a href="/" class="logo">Eric Daoud Attoyan</a>
        <nav>
          <a href="/music" class:list={[{ active: currentPath === '/music' }]}>music</a>
          <a href="/photography" class:list={[{ active: currentPath === '/photography' }]}>photography</a>
          <a href="/blog" class:list={[{ active: currentPath.startsWith('/blog') }]}>blog</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer>
        <div class="footer-row">
          <div class="links">
            <a href="https://github.com/ericdaat" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              github
            </a>
            <a href="https://www.linkedin.com/in/ericdaoud/" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              linkedin
            </a>
          </div>
          <button id="theme-toggle" aria-label="Toggle dark mode" class="theme-toggle">
            <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
        </div>
      </footer>
    </div>
    <script>
      const toggle = document.getElementById('theme-toggle');
      const root = document.documentElement;

      const saved = localStorage.getItem('theme');
      if (saved) root.setAttribute('data-theme', saved);

      toggle?.addEventListener('click', () => {
        const isDark = root.getAttribute('data-theme') === 'dark' ||
          (!root.getAttribute('data-theme') && window.matchMedia('(prefers-color-scheme: dark)').matches);
        const next = isDark ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });
    </script>
  </body>
</html>

<style>
  :global(:root) {
    --color-text: #1a1a1a;
    --color-bg: #fafafa;
    --color-muted: #666;
    --color-faint: #888;
    --color-border: #e0e0e0;
    --color-hover: #555;
  }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) {
      --color-text: #e0e0e0;
      --color-bg: #141414;
      --color-muted: #999;
      --color-faint: #777;
      --color-border: #333;
      --color-hover: #bbb;
    }
  }

  :global(:root[data-theme='dark']) {
    --color-text: #e0e0e0;
    --color-bg: #141414;
    --color-muted: #999;
    --color-faint: #777;
    --color-border: #333;
    --color-hover: #bbb;
  }

  :global(*) {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :global(body) {
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, 'DejaVu Sans Mono', monospace;
    color: var(--color-text);
    background: var(--color-bg);
    font-size: 16px;
    line-height: 1.7;
  }

  :global(p) {
    text-align: justify;
  }

  :global(a) {
    color: var(--color-text);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  :global(a:hover) {
    color: var(--color-hover);
  }

  .container {
    max-width: 700px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 4rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .logo {
    font-weight: 600;
    text-decoration: none;
    font-size: 0.95rem;
  }

  nav {
    display: flex;
    gap: 1.5rem;
    font-size: 0.9rem;
  }

  nav a {
    text-decoration: none;
    color: var(--color-muted);
  }

  nav a:hover,
  nav a.active {
    color: var(--color-text);
  }

  main {
    flex: 1;
  }

  footer {
    margin-top: 4rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.85rem;
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .links {
    display: flex;
    gap: 1rem;
  }

  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-faint);
    padding: 0.25rem;
    display: flex;
    align-items: center;
  }

  .theme-toggle:hover {
    color: var(--color-text);
  }

  .icon-sun, .icon-moon {
    display: none;
  }

  :global(:root:not([data-theme])) .icon-sun,
  :global(:root[data-theme='light']) .icon-sun {
    display: block;
  }

  :global(:root[data-theme='dark']) .icon-moon {
    display: block;
  }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme])) .icon-sun {
      display: none;
    }
    :global(:root:not([data-theme])) .icon-moon {
      display: block;
    }
  }

  .links a {
    color: var(--color-faint);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .links a:hover {
    color: var(--color-text);
  }

  @media (max-width: 500px) {
    header {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>
